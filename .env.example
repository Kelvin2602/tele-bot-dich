# === Telegram Bot Token ===
# Lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# === Provider API (OpenAI hoặc OpenAI-compatible: opencode.ai/zen, DeepSeek, OpenRouter, ...) ===
# Mặc định dùng OpenAI Chat Completions format. Hỗ trợ bất kỳ endpoint
# nào tuân thủ OpenAI API (vd: DeepSeek, OpenRouter, custom proxy).

# OpenAI chính thức:
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=
#   OPENAI_MODEL=gpt-4o-mini
#
# opencode.ai/zen (khuyên dùng — mimo-v2.5-free nhanh & ổn định nhất):
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://opencode.ai/zen/v1
#   OPENAI_MODEL=mimo-v2.5-free
#
# OpenRouter:
#   OPENAI_API_KEY=sk-or-...
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=openrouter/free
#
# iamhc.cn (có cold start ~30s):
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://api.iamhc.cn/v1
#   OPENAI_MODEL=step-3.5-flash

OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://opencode.ai/zen/v1
OPENAI_MODEL=mimo-v2.5-free

# Timeout khi gọi API (giây). 30s là đủ cho hầu hết model free.
OPENAI_TIMEOUT_SECONDS=30

# Số lần retry tự động của OpenAI SDK khi gặp lỗi.
# 0 = fail-fast (khuyên dùng cho free tier — tránh 117s+ timeout).
# Mặc định SDK = 2, nhưng với cold start 60-80s thì 3 lần × 60s + backoff ≈ 200s.
OPENAI_MAX_RETRIES=0

# Bật/tắt thinking mode (pass qua `extra_body={"enable_thinking": false}`).
# Một số model (GLM-4.7, Qwen3, ...) mặc định bật thinking → dễ rate limit.
# false = tắt (khuyên dùng cho production).
ENABLE_THINKING=false

# === Bot behavior ===
# Ngôn ngữ đích mặc định khi user chưa /set_target
DEFAULT_TARGET_LANG=vi

# Giới hạn ký tự / tin nhắn (Telegram giới hạn 4096, để an toàn dùng 4000)
MAX_TEXT_LENGTH=4000

# === Logging ===
# Một trong: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === Rate Limiting ===
# Giới hạn số request mỗi user để tránh spam và bảo vệ quota API.
# Mỗi user được tối đa RATE_LIMIT_MAX_REQUESTS request trong RATE_LIMIT_WINDOW_SECONDS giây.
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# === Webhook (cho production trên Render) ===
# Bật webhook thay vì polling. Mặc định false (dùng polling cho dev local).
# WEBHOOK_ENABLED=true
#
# Public URL — Render tự set RENDER_EXTERNAL_URL, hoặc bạn có thể set thủ công:
# WEBHOOK_URL=https://tele-bot-dich.onrender.com
#
# Render tự động set PORT env. Nếu không, dùng mặc định 8443:
# WEBHOOK_PORT=8443
#
# Path cho webhook endpoint (mặc định /webhook):
# WEBHOOK_PATH=/webhook
#
# Secret token xác thực webhook (khuyến nghị dùng cho production):
# WEBHOOK_SECRET_TOKEN=your-secret-token-here
